<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1D9E75"
            android:padding="16dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/btnBack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="← "
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Daily Report"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Summary Cards -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="#E1F5EE"
                android:padding="12dp"
                android:orientation="vertical"
                android:layout_marginEnd="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Given"
                    android:textColor="#0F6E56"
                    android:textSize="11sp"/>

                <TextView
                    android:id="@+id/tvTotalGiven"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0"
                    android:textColor="#0F6E56"
                    android:textSize="22sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="#FCEBEB"
                android:padding="12dp"
                android:orientation="vertical"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Received"
                    android:textColor="#C62828"
                    android:textSize="11sp"/>

                <TextView
                    android:id="@+id/tvTotalReceived"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0"
                    android:textColor="#C62828"
                    android:textSize="22sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="#E6F1FB"
                android:padding="12dp"
                android:orientation="vertical"
                android:layout_marginStart="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Net Due"
                    android:textColor="#0C447C"
                    android:textSize="11sp"/>

                <TextView
                    android:id="@+id/tvNetDue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0"
                    android:textColor="#0C447C"
                    android:textSize="22sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Top Dues Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TOP OUTSTANDING DUES"
            android:textColor="#757575"
            android:textSize="11sp"
            android:paddingStart="14dp"
            android:paddingBottom="6dp"
            android:textAllCaps="true"/>

        <LinearLayout
            android:id="@+id/layoutTopDues"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="14dp"
            android:orientation="vertical"/>

        <!-- AI Insight Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI INSIGHT"
            android:textColor="#757575"
            android:textSize="11sp"
            android:paddingStart="14dp"
            android:paddingTop="14dp"
            android:paddingBottom="6dp"
            android:textAllCaps="true"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FAEEDA"
                android:padding="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✨ "
                    android:textSize="16sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gemini AI Daily Insight"
                    android:textColor="#BA7517"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvAiInsight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Generating insight..."
                android:textColor="#424242"
                android:textSize="13sp"
                android:padding="14dp"
                android:lineSpacingExtra="4dp"/>

            <Button
                android:id="@+id/btnRefreshInsight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:text="Refresh AI Insight"
                android:textColor="#BA7517"
                android:backgroundTint="#FAEEDA"
                android:textAllCaps="false"/>
        </LinearLayout>

        <!-- All Customers Summary -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ALL CUSTOMERS SUMMARY"
            android:textColor="#757575"
            android:textSize="11sp"
            android:paddingStart="14dp"
            android:paddingBottom="6dp"
            android:textAllCaps="true"/>

        <LinearLayout
            android:id="@+id/layoutAllCustomers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="14dp"
            android:orientation="vertical"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>